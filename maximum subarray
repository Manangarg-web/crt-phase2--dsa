Leetcode maximum subarray

brute force
class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int n = nums.size();
        int maxsum=INT_MIN;
        
        for (int i =0;i<n;i++){
            int sum = 0;
            for (int j =i;j<n;j++){
                sum=sum+nums[j];
                maxsum=max(sum,maxsum);

            }
        }
        return maxsum;
    }
};

optimal approach
class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int count = 0;
        int maxcount = -1;
        int sum = 0;
        int maxsum=INT_MIN;

        for (int i=0;i<nums.size();i++){
            sum=sum+nums[i];
            
            maxsum=max(sum,maxsum);
            if(sum<0){
              
                sum = 0;
            }
  
        }
        return maxsum;
    }
};

