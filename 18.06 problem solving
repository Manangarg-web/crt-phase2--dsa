1]Majority elements
class Solution {
public:
    int majorityElement(vector<int>&  nums) {
        int major = nums[0];
        int count=0;
        for (int i =0;i<nums.size();i++){
            if(count==0){
                major = nums[i];

            }
            if(nums[i]==major){
                count++;
            }
            else{
                count--;
            }
        }
        return major;
    }
};


2] Q31:TWO SUM 2


BRUTE FORCE
USING HASHMAP
CONS: EXTRA SPACE
class Solution {
public:
    vector<int> twoSum(vector<int>& numbers, int target) {
        unordered_map<int,int>mp;
        int n = numbers.size();
        for(int i = 0;i<n;i++){
            int need = target-numbers[i];
            if(mp.find(need)!=mp.end()){
                return{mp[need]+1,i+1};
            }
            mp[numbers[i]]=i;


        }
        return {-1,-1};
    }
};

OPTIMAL APPROACH
using binary search

class Solution {
public:
    vector<int> twoSum(vector<int>& numbers, int target) {
        unordered_map<int,int>mp;
        int n = numbers.size();
        int low = 0 ;
        int high = n-1;
            while(low<high){
                int sum = numbers[low]+numbers[high];
                if(sum==target){
                    return {low+1,high+1};
                }
                else if(sum >target){
                    high--;
                }
                else{
                    low++;
                }
            }
        
        return {-1,-1};
    }
};

